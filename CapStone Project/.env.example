# Copy to .env if you want API-backed reference validation.
# Offline mode works without these values.

CLAIMGUARD_ENABLE_APIS=false
CROSSREF_MAILTO=your-email@example.com
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_MAILTO=your-email@example.com

# Optional local embedding retrieval. If enabled, the model must already be cached
# because ClaimGuard requests local files only and does not download at runtime.
CLAIMGUARD_USE_EMBEDDINGS=auto
CLAIMGUARD_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
