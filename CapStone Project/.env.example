# Copy this file to .env and insert secrets only in .env.
# Never place real API keys in this example file.

CLAIMGUARD_ENABLE_APIS=false
CROSSREF_MAILTO=your-email@example.com
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_MAILTO=your-email@example.com
UNPAYWALL_EMAIL=your-email@example.com
CLAIMGUARD_FETCH_FULL_TEXT=false
CLAIMGUARD_MAX_FULL_TEXT_SOURCES=3

CLAIMGUARD_USE_EMBEDDINGS=auto
CLAIMGUARD_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CLAIMGUARD_EMBEDDING_LOCAL_ONLY=true

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:1.7b

# API billing is separate from a ChatGPT subscription.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# Optional when an account has multiple projects or organizations.
OPENAI_PROJECT_ID=
OPENAI_ORGANIZATION_ID=

CLAIMGUARD_LORA_MODEL=outputs/models/scifact-lora

BINOCULARS_OBSERVER_MODEL=
BINOCULARS_PERFORMER_MODEL=

# Official FastDetect API; each paragraph consumes one API call/credit.
FASTDETECT_API_KEY=
FASTDETECT_API_ENDPOINT=https://api.fastdetect.net/api/detect
FASTDETECT_MODEL=fast-detect(llama3-8b/llama3-8b-instruct)
FASTDETECT_THRESHOLD=0.5
